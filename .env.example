PORT=8080
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
AUTH_SECRET=your-auth-secret-same-as-nextjs
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# Resend email (https://resend.com)
RESEND_API_KEY=re_your_api_key
RESEND_FROM=onboarding@resend.dev
# Set to your own email while using Resend without a verified domain (free tier)
RESEND_TO_OVERRIDE=you@gmail.com

# Google Calendar OAuth (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/calendar/callback
